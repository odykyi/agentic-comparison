{
  "name": "agentic-comparison",
  "version": "1.0.0",
  "description": "🎨 AI Skills Marketplace - Compare 10+ agentic coding tools, discover 40+ AI skills, find MCP servers. The ultimate skills marketplace for AI coding agents.",
  "scripts": {
    "validate": "python scripts/validate.py",
    "build": "bundle exec jekyll build",
    "serve": "bundle exec jekyll serve --livereload",
    "clean": "bundle exec jekyll clean",
    "test": "bundle exec htmlproofer ./_site --disable-external",
    "format": "prettier --write '_data/**/*.yml'",
    "lint": "prettier --check '_data/**/*.yml'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/odykyi/agentic-comparison.git"
  },
  "keywords": [
    "ai-agents",
    "coding-tools",
    "comparison",
    "jekyll",
    "claude-code",
    "codex",
    "opencode",
    "skills",
    "skills-marketplace",
    "ai-skills",
    "agent-skills",
    "skill-registry",
    "mcp",
    "mcp-servers",
    "model-context-protocol",
    "ai-tools",
    "llm-tools",
    "developer-tools",
    "cursor",
    "windsurf",
    "aider",
    "continue-dev"
  ],
  "author": "Agentic Comparison Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/odykyi/agentic-comparison/issues"
  },
  "homepage": "https://odykyi.github.io/agentic-comparison/",
  "devDependencies": {
    "prettier": "^3.1.0"
  }
}
