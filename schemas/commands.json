{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Commands Mapping Schema",
  "type": "object",
  "properties": {
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical_name", "description", "implementations"],
        "properties": {
          "canonical_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "general",
              "file",
              "git",
              "search",
              "edit",
              "debug",
              "test",
              "deploy"
            ]
          },
          "implementations": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string"
                },
                "flags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
