{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Terminology Mapping Schema",
  "type": "object",
  "properties": {
    "canonical_concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "tool_names"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tool_names": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tool": {
                  "type": "string"
                },
                "version": {
                  "type": "string"
                },
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "date": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          }
        }
      }
    }
  }
}
